
@if (_isLoading)
{
    <Spinner />
}
else
{
    if (!_imagesFound)
    {
        <p><span>@_lc.Keys["NoImagesWereFound"]</span></p>
        <p><span>@_lc.Keys["LocationPathColon"] @_locationPath</span></p>
        <p><span>@_lc.Keys["NationalPathColon"] @_nationalPath</span></p>
    }
    else
    {
        <img src="@_imagePath" id="@ImageId" class="slider-angle-img" height="500" width="100%" alt="Rotator image" />
    }
}
